# Auth + tRPC are hosted by the portfolio app
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Shared Neon database (same as packages/drizzle / apps/portfolio)
DATABASE_URL="postgresql://user:password@host/db"
BETTER_AUTH_SECRET="same-secret-as-the-other-apps"

# Canonical URL of this app (prod: https://cms.alisamadii.com)
BASE_URL="http://localhost:3007"

# GitHub org holding all client repos (the org PAT lives in apps/portfolio)
GITHUB_ORG="your-github-org"

# Org webhook HMAC secret (configured manually in the org's webhook settings)
GITHUB_WEBHOOK_SECRET="random-string-of-characters"

# Shared secret for server-to-server tRPC calls to the portfolio app
# (must match the portfolio app's INTERNAL_API_SECRET)
INTERNAL_API_SECRET="another-random-string-of-characters"

# Email (collaborator invites)
EMAIL_FROM="Ali Samadi <no-reply@alisamadii.com>"
# EMAIL_PROVIDER="agency" # or "resend" or "smtp"
# AGENCY_API_KEY="ak_ser_your-agency-api-key"
# RESEND_API_KEY="your-resend-api-key"

# Cache tuning (optional)
# CACHE_CHECK_MIN=5
# CONFIG_CHECK_MIN=5
# FILE_TTL_MIN=1440
# BRANCH_HEAD_TTL_MS=15000
# REPO_META_TTL_MS=15000
# WEBHOOK_PUSH_INCREMENTAL_MAX_FILES=120
# WEBHOOK_PUSH_SCOPED_INVALIDATION_MAX_FILES=800
